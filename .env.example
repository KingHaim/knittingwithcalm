# Copy this file to .env and fill in real values. Do NOT commit .env.

# === Supabase backend (self-hosted on Railway) ===
# VITE_SUPABASE_URL      -> public URL of the Kong/API gateway service
#                           (e.g. https://kong-production-xxxx.up.railway.app)
# VITE_SUPABASE_ANON_KEY -> the anon JWT (role "anon") signed with the stack's JWT_SECRET
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# === Resend (optional - for sending newsletter welcome emails) ===
# VITE_RESEND_API_KEY=re_your_api_key_here
# VITE_RESEND_FROM_EMAIL=Knitting With Calm <newsletter@knittingwithcalm.com>
